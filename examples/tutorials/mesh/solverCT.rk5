# This file is setting the parameters for the solver to use in the
# simulations. See documentation for availble solvers.
#
# Contact: henrik.jonsson@slcu.cam.ac.uk
#
RK5Adaptive   # solver to be used
0 10          # start time, end time (default 0 10)
7 10	      # output format (7->vtk with centralTriangulation), data points (7 10)
0.5 1e-5      # max step, error tolerance (0.1 1e-5)
